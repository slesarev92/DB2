# ============================================================
# Пример переменных окружения. Скопируйте в .env и заполните.
# .env в репозиторий НЕ коммитится (см. .gitignore).
# ============================================================

# --- Database (PostgreSQL 16) ---
DATABASE_URL=postgresql+asyncpg://dbuser:dbpassword@localhost:5432/dbpassport

# --- Redis (cache + Celery broker + Celery result backend) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Security / JWT (ADR-08) ---
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# --- Frontend (Next.js public env) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- AI integration (Polza AI, Фаза 7 / post-MVP, ADR-16) ---
# Polza AI = OpenAI-совместимый прокси с оплатой в рублях, без VPN.
# Используется через openai Python SDK (AsyncOpenAI) с кастомным base_url.
# Формат model: "<provider>/<model_id>".
# Дефолт по ADR-16:
#   - "anthropic/claude-sonnet-4-6"  — обычные задачи (комментарии, summary)
#   - "anthropic/claude-opus-4-6"    — сложные (аудит формул, объяснение KPI)
# Зависимость openai>=1.0 добавляется в requirements.txt в Фазе 7, не сейчас.
POLZA_AI_API_KEY=
POLZA_AI_BASE_URL=https://api.polza.ai/api/v1
