# Нормализация переносов строк при работе из Windows в Docker (Linux)
# и между разработчиками на разных OS.
* text=auto eol=lf

# --- Binary files (не нормализовать) ---
*.xlsx binary
*.xlsm binary
*.xls  binary
*.docx binary
*.doc  binary
*.pdf  binary
*.pptx binary
*.ppt  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.otf  binary

# --- Явно текстовые файлы с LF ---
*.py        text eol=lf
*.pyi       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.sql       text eol=lf
*.sh        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
Dockerfile  text eol=lf
.dockerignore text eol=lf
.env.example  text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf
